# ==============================================================================
# Dockerfile.api — image de l'API FastAPI (fournie)
# ==============================================================================
FROM python:3.13-slim

WORKDIR /app

COPY pyproject.toml .
RUN pip install --no-cache-dir uv && uv sync --no-dev

COPY src/ src/
COPY models/ models/

EXPOSE 8000

CMD ["uv", "run", "uvicorn", "heart.api:app", \
     "--host", "0.0.0.0", "--port", "8000"]
